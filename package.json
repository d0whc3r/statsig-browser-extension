{
  "name": "statsig-browser-extension",
  "version": "1.4.3",
  "private": true,
  "description": "Manage Statsig feature gates and experiments directly from your browser. View user details, override gates, and debug efficiently.",
  "keywords": [
    "ab-testing",
    "browser-extension",
    "developer-tools",
    "experimentation",
    "feature-flags",
    "statsig"
  ],
  "homepage": "https://github.com/d0whc3r/statsig-browser-extension#readme",
  "bugs": {
    "url": "https://github.com/d0whc3r/statsig-browser-extension/issues"
  },
  "license": "ISC",
  "author": "d0whc3r",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/d0whc3r/statsig-browser-extension.git"
  },
  "type": "module",
  "scripts": {
    "dev": "wxt",
    "dev:firefox": "wxt -b firefox",
    "dev:chrome": "wxt -b chrome",
    "build": "wxt build",
    "build:firefox": "wxt build -b firefox",
    "build:chrome": "wxt build -b chrome",
    "zip": "wxt zip",
    "zip:firefox": "wxt zip -b firefox",
    "zip:chrome": "wxt zip -b chrome",
    "zip:all": "pnpm zip:chrome && pnpm zip:firefox",
    "prepare": "husky && wxt prepare",
    "compile": "tsc --noEmit",
    "postinstall": "wxt prepare",
    "lint": "oxlint --no-error-on-unmatched-pattern",
    "lint:fix": "pnpm lint --fix",
    "format:fix": "pnpm lint:fix --fix-suggestions --fix-dangerously && pnpm format",
    "format": "oxfmt --no-error-on-unmatched-pattern --write",
    "format:check": "oxfmt --no-error-on-unmatched-pattern --check",
    "type-check": "tsc --noEmit -p tsconfig.app.json && tsc --noEmit -p tsconfig.test.json && tsc --noEmit -p tsconfig.e2e.json",
    "knip": "knip",
    "knip:fix": "knip --fix --allow-remove-files",
    "knip:production": "knip --production --strict",
    "test": "vitest",
    "test:e2e": "pnpm build:chrome && playwright test",
    "test:e2e:ui": "playwright test --ui",
    "pre-push": "pnpm test",
    "pre-commit": "lint-staged"
  },
  "dependencies": {
    "@fontsource/inter": "5.2.8",
    "@hookform/resolvers": "5.4.0",
    "@radix-ui/react-tabs": "1.1.17",
    "@radix-ui/react-tooltip": "1.2.12",
    "@tanstack/react-query": "5.101.2",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "fuse.js": "7.5.0",
    "lucide-react": "1.26.0",
    "radix-ui": "1.6.2",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-hook-form": "7.81.0",
    "tailwind-merge": "3.6.0",
    "tw-animate-css": "1.4.0",
    "wretch": "3.0.9",
    "zod": "4.4.3",
    "zustand": "5.0.14"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@semantic-release/changelog": "6.0.3",
    "@semantic-release/exec": "7.1.0",
    "@semantic-release/git": "10.0.1",
    "@tailwindcss/postcss": "4.3.2",
    "@testing-library/dom": "10.4.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@total-typescript/ts-reset": "0.6.1",
    "@types/chrome": "0.2.2",
    "@types/node": "^24.12.2",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@types/webextension-polyfill": "0.12.5",
    "@vitejs/plugin-react": "6.0.3",
    "@vitest/coverage-v8": "4.1.10",
    "@vitest/ui": "4.1.10",
    "@wxt-dev/module-react": "1.2.2",
    "autoprefixer": "10.5.2",
    "happy-dom": "20.10.6",
    "husky": "9.1.7",
    "knip": "6.26.0",
    "lint-staged": "17.0.8",
    "oxfmt": "0.59.0",
    "oxlint": "1.74.0",
    "oxlint-tsgolint": "0.24.0",
    "postcss": "8.5.19",
    "postcss-load-config": "6.0.1",
    "semantic-release": "25.0.7",
    "tailwindcss": "4.3.2",
    "typescript": "7.0.2",
    "vitest": "4.1.10",
    "webextension-polyfill": "0.12.0",
    "wxt": "0.20.27"
  },
  "lint-staged": {
    "*": [
      "oxlint --no-error-on-unmatched-pattern --fix",
      "oxfmt --no-error-on-unmatched-pattern --write"
    ]
  },
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=10.0.0"
  },
  "packageManager": "pnpm@11.13.0"
}
